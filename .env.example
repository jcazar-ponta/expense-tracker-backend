DEBUG=True
ENVIRONMENT=develop
DJANGO_SETTINGS_MODULE=config.settings.develop
DJANGO_PORT=8000
SECRET_KEY=django-insecure-local-dev-key
ALLOWED_HOSTS=*

DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=False

JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=replace-me
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=14
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

PUBLIC_SHARE_BASE_URL=http://localhost:5000
SHARE_TOKEN_PEPPER=replace-with-random-secret
PUBLIC_PAYABLES_THROTTLE_RATE=60/min
